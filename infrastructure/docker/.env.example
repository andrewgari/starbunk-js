# ===========================================================================
# Starbunk Docker Environment — Unraid Deployment
# ===========================================================================
# Copy this file to .env and fill in the required values before running
# docker-compose up. Variables marked REQUIRED must be set; all others
# have working defaults.
#
# Quick start (CovaBot only):
#   DISCORD_TOKEN, POSTGRES_PASSWORD, GEMINI_API_KEY
# ===========================================================================

# ---------------------------------------------------------------------------
# HOST CONFIGURATION (Unraid)
# ---------------------------------------------------------------------------
# Absolute path to the starbunk deployment directory on the Unraid host.
# All config/ and data/ subdirectories are relative to this path.
HOST_WORKDIR=/mnt/user/appdata/starbunk

# ---------------------------------------------------------------------------
# DISCORD TOKENS
# ---------------------------------------------------------------------------
# You can use a single shared token for all bots OR separate tokens per bot.
# If per-bot tokens are not set, STARBUNK_TOKEN is used as the fallback.

# REQUIRED — at least one of these must be set:
STARBUNK_TOKEN=          # Shared fallback token (all bots)
# BUNKBOT_TOKEN=         # Optional: dedicated BunkBot token
# DJCOVA_TOKEN=          # Optional: dedicated DJCova token
# COVABOT_TOKEN=         # Optional: dedicated CovaBot token  ← most important
# BLUEBOT_TOKEN=         # Optional: dedicated BlueBot token

# ---------------------------------------------------------------------------
# LLM PROVIDERS (CovaBot)
# ---------------------------------------------------------------------------
# Priority order: Gemini → Ollama → OpenAI
# At least one provider must be configured for CovaBot to respond.

# Gemini (primary — free tier available at aistudio.google.com)
GEMINI_API_KEY=          # REQUIRED for CovaBot LLM responses
GEMINI_DEFAULT_MODEL=gemini-1.5-flash

# Ollama (first fallback — local LLM, runs on the same Unraid machine)
# OLLAMA_API_URL=http://host.docker.internal:11434
# OLLAMA_DEFAULT_MODEL=mistral:latest

# OpenAI (second fallback — paid)
# OPENAI_API_KEY=
# OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# POSTGRESQL (REQUIRED)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=       # REQUIRED — choose a strong password
POSTGRES_USER=starbunk
POSTGRES_DB=starbunk
POSTGRES_HOST=starbunk-postgres
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# ENVIRONMENT & LOGGING
# ---------------------------------------------------------------------------
ENVIRONMENT=production
LOG_LEVEL=info
LOG_FORMAT=json

# ---------------------------------------------------------------------------
# OBSERVABILITY (optional — OpenTelemetry collector)
# ---------------------------------------------------------------------------
# Set OBSERVABILITY_HOST to your Unraid IP if you run Prometheus/Loki/Tempo.
# OBSERVABILITY_HOST=192.168.1.x
# PROMETHEUS_PORT=9090
# LOKI_PORT=3100
# TEMPO_PORT=4317
ENABLE_METRICS=true
ENABLE_STRUCTURED_LOGGING=true

# ---------------------------------------------------------------------------
# DEBUG / TESTING (leave empty in production)
# ---------------------------------------------------------------------------
# TESTING_SERVER_IDS=    # Restrict bot to specific Discord guild IDs
# TESTING_CHANNEL_IDS=   # Restrict bot to specific channel IDs
DEBUG_MODE=false
CI_SMOKE_MODE=false
