        reason: 'Dev dependency bundled in npm package used only in CI for semantic-release. Not in production.'
        expires: '2026-07-19T00:00:00.000Z'

  # High severity: Uncontrolled Resource Consumption in @isaacs/brace-expansion
  # Bundled inside npm@11.x which is bundled in @semantic-release/npm
  GHSA-7h2j-956f-4vf2:
    - 'semantic-release > @semantic-release/npm > npm > @isaacs/brace-expansion':
        reason: 'Dev dependency bundled in npm package used only in CI for semantic-release. Not in production.'
        expires: '2026-10-19T00:00:00.000Z'

  # High severity: ReDoS vulnerabilities in minimatch
