# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.0

# Ignore vulnerabilities in devDependencies that are bundled inside npm package
# These only run during semantic-release in GitHub Actions CI environment
# Risk: LOW - controlled environment, not in production containers

ignore:
  # High severity: Path Traversal vulnerability in tar package (<=7.5.2)
  # Bundled inside npm@11.7.0 which is bundled in @semantic-release/npm
  # Only affects semantic-release process during CI/CD
  SNYK-JS-TAR-8239548:
    - 'semantic-release > @semantic-release/npm > npm > tar':
        reason: 'Dev dependency bundled in npm package used only in CI for semantic-release. Not in production.'
        expires: '2026-07-19T00:00:00.000Z'
    - 'semantic-release > @semantic-release/npm > npm > pacote > tar':
        reason: 'Dev dependency bundled in npm package used only in CI for semantic-release. Not in production.'
        expires: '2026-07-19T00:00:00.000Z'
    - 'semantic-release > @semantic-release/npm > npm > node-gyp > tar':
        reason: 'Dev dependency bundled in npm package used only in CI for semantic-release. Not in production.'
        expires: '2026-07-19T00:00:00.000Z'
    - 'semantic-release > @semantic-release/npm > npm > libnpmdiff > tar':
        reason: 'Dev dependency bundled in npm package used only in CI for semantic-release. Not in production.'
        expires: '2026-07-19T00:00:00.000Z'

  'npm:tar:20241218':
    - 'semantic-release > @semantic-release/npm > npm > tar':
        reason: 'Dev dependency bundled in npm package used only in CI for semantic-release. Not in production.'
