        reason: 'Dev dependency bundled in npm package used only in CI for semantic-release. Not in production.'
        expires: '2026-07-19T00:00:00.000Z'

  SNYK-JS-TAR-7932124:
    - 'semantic-release > @semantic-release/npm > npm > tar':
        reason: 'Dev dependency bundled in npm package used only in CI for semantic-release. Not in production.'
        expires: '2026-07-19T00:00:00.000Z'

  # Low severity: ReDoS vulnerability in diff package (<8.0.3)
  # Bundled inside npm@11.7.0 which is bundled in @semantic-release/npm
  # Only affects semantic-release process during CI/CD
  SNYK-JS-DIFF-8239547:
